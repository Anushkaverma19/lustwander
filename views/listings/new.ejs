<% layout('layout/boilerplate') %>

<div class="row">
  <div class="col-8 offset-2">

    <h1 class="mb-4">Create New Listing</h1>

    <form class="needs-validation" action="/listings" method="POST" enctype="multipart/form-data"  novalidate>

      <div class="mb-3">
        <label class="form-label">Title</label>
        <input 
          type="text" 
          name="listing[title]" 
          class="form-control"
          required
        >
         <div class="valid-feedback">
      Looks good!
    </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea 
          name="listing[description]" 
          class="form-control"
     
        ></textarea>
        <div class="invalid-feedback">
      Please provide a short description.
    </div>
      </div>

      <!-- Main Image -->
<div class="mb-3">
  <label class="form-label">Main Image</label>
  <input 
    type="file" 
    name="mainImage" 
    class="form-control"
    accept="image/*"
    required
  >
</div>

<!-- Additional Images -->
<div class="mb-3">
  <label class="form-label">Additional Images</label>
  <input 
    type="file" 
    name="otherImages" multiple
    class="form-control"
    accept="image/*"
    multiple
  >
  <small class="text-muted">You can select multiple files here.</small>
</div>


      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label">Price</label>
          <input 
            type="number" 
            name="listing[price]" 
            class="form-control"
            required
          >
          <div class="invalid-feedback">
      Please provide a valid price.
    </div>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label">Country</label>
          <input 
            type="text" 
            name="listing[country]" 
            class="form-control"
            required
          >
          <div class="invalid-feedback">
      Please provide a valid city.
    </div>
        </div>
      </div>
  
      <button class="btn btn-dark">Create Listing</button>

    </form>

  </div>
</div>